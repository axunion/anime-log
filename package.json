{
  "name": "anime-log",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "typecheck": "vue-tsc --noEmit",
    "check": "biome check src scripts vite.config.ts",
    "fix": "biome check --write src scripts vite.config.ts",
    "migrate:generate": "pnpm exec tsx scripts/migrate.ts",
    "db:migrate": "wrangler d1 migrations apply anime-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply anime-db --remote",
    "test:client": "vitest run --config vitest.config.ts",
    "test:server": "vitest run --config vitest.workers.config.ts",
    "test": "pnpm run test:client && pnpm run test:server",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "lucide-vue-next": "^0.468.0",
    "vue": "^3.5.32"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@cloudflare/vite-plugin": "^1.31.0",
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@cloudflare/workers-types": "^4.20250405.0",
    "@types/node": "^22.15.3",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.9.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^8.0.5",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.80.0"
  }
}
